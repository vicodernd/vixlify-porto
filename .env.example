# Copy to .env.local and fill in. These are PUBLIC client keys (Supabase
# publishable / anon) — they ship in the browser bundle by design.
# Also set the same two vars in the Vercel project (Settings → Environment Variables).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
